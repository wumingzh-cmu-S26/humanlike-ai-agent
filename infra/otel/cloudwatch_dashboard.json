{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "API Request Rate (rpm)",
        "metrics": [
          ["humanlike-ai-agent", "http.server.request.count", "service.name", "humanlike-ai-agent", { "stat": "Sum", "period": 60 }]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "API p50 / p95 / p99 latency (ms)",
        "metrics": [
          ["humanlike-ai-agent", "http.server.duration", { "stat": "p50" }],
          ["...", { "stat": "p95" }],
          ["...", { "stat": "p99" }]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "Circuit Breaker Open Count",
        "metrics": [
          ["humanlike-ai-agent", "circuit_breaker.open", "breaker", "openai_chat", { "stat": "Sum" }],
          ["...", "openai_embeddings"],
          ["...", "google_calendar"],
          ["...", "telegram_out"],
          ["...", "slack_out"]
        ],
        "view": "timeSeries",
        "stacked": true,
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "RAG Retrieval Latency (ms)",
        "metrics": [
          ["humanlike-ai-agent", "rag.retrieval.duration", { "stat": "p95" }]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "title": "ECS CPU / Memory",
        "metrics": [
          ["AWS/ECS", "CPUUtilization", "ServiceName", "humanlike-ai-agent", "ClusterName", "ai-cluster"],
          [".", "MemoryUtilization", ".", ".", ".", "."]
        ],
        "view": "timeSeries",
        "region": "us-east-1"
      }
    },
    {
      "type": "log",
      "x": 12,
      "y": 12,
      "width": 12,
      "height": 6,
      "properties": {
        "query": "SOURCE '/ecs/humanlike-ai-agent' | fields @timestamp, level, event, error\n| filter level = \"error\" or level = \"warning\"\n| sort @timestamp desc\n| limit 50",
        "region": "us-east-1",
        "title": "Recent Errors & Warnings"
      }
    }
  ]
}
