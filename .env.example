# ============================================================================
# Application
# ============================================================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ============================================================================
# Auth (JWT)
# ============================================================================
JWT_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================================
# OpenAI
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# ============================================================================
# RAG / Vector Stores
# ============================================================================
CHROMA_PERSIST_DIR=./data/chroma
FAISS_INDEX_PATH=./data/faiss.index
RAG_TOP_K=8
RAG_RERANK_TOP_K=4
RAG_RRF_K=60
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ============================================================================
# Memory
# ============================================================================
MEMORY_WINDOW_SIZE=10
MEMORY_SUMMARY_TOKEN_LIMIT=2000
LONG_TERM_MEMORY_TOP_K=5
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Personality
# ============================================================================
DEFAULT_PERSONALITY=companion
PERSONALITY_DIR=./personalities

# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# Slack
# ============================================================================
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...

# ============================================================================
# Google (Calendar / Tasks)
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback
GOOGLE_TOKEN_DIR=./data/google_tokens

# ============================================================================
# Azure TTS
# ============================================================================
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=en-US-JennyNeural

# ============================================================================
# Circuit breaker
# ============================================================================
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ============================================================================
# Rate limiting
# ============================================================================
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Observability
# ============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=humanlike-ai-agent
OTEL_TRACES_SAMPLER_ARG=1.0

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
